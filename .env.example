# DocuForge — Configuration
# Copy this file to .env and customize
# ============================================================

# ---- Ollama ----
# Hostname and port of the Ollama API server
# Default points to the ollama service in docker-compose
OLLAMA_HOST=http://ollama:11434

# Model used for OCR (vision model — must be pulled in Ollama first)
OCR_MODEL=glm-ocr

# Model used for renaming & tagging (text model — must be pulled in Ollama first)
TAGGING_MODEL=llama3.2

# ---- Processing ----
# Dots-per-inch when rendering PDF pages for OCR. Higher = better OCR, slower.
# Typical: 300 for quality, 150 for speed.
DPI=300

# PDF/A conformance level. "2b" is most common for scanned docs.
# Options: 2b, 3b
PDFA_LEVEL=2b

# ---- File Handling ----
# Maximum upload size in megabytes
MAX_FILE_SIZE_MB=100

# How often (in seconds) the folder watcher scans for new files (Sprint 3)
WATCH_INTERVAL=5

# ---- Renaming & Tagging ----
# If "true", auto-apply LLM-suggested name and tags without user approval.
# If "false", jobs pause at "awaiting_approval" until user confirms.
AUTO_RENAME=false

# Prompt template for the LLM that renames and tags documents.
# Uses {ocr_text} placeholder which is replaced with the extracted text.
RENAME_PROMPT="You are a document archivist. Given the following OCR'd text from a document, suggest:\n1. A concise, descriptive filename (without extension, max 150 chars). Use underscores between words. Include the date if present.\n2. Up to 5 relevant tags that describe the document type, parties, subject, and year.\n\nReturn ONLY valid JSON in this exact format:\n{\"filename\": \"suggested_name\", \"tags\": [\"tag1\", \"tag2\", \"tag3\"]}\n\nDocument text:\n{ocr_text}"
